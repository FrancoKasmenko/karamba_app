# Database (Docker Compose: host es el servicio `db`, no uses localhost para la DB)
DATABASE_URL="postgresql://karamba:Majo1984_@db:5432/karamba?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-super-secret-key-change-this"
# Incluí el path /_k/auth para que las llamadas de sesión vayan a /_k/auth/* (no /api/auth/*).
# Local:
NEXTAUTH_URL="http://localhost:3000/_k/auth"
# Producción (VPS con dominio, HTTPS):
# NEXTAUTH_URL="https://karamba.com.uy/_k/auth"

# URL pública del sitio (metadata SEO, sitemap, Open Graph, fallback si BASE_URL es IP)
NEXT_PUBLIC_SITE_URL="https://karamba.com.uy"

# Cloudinary (optional - for image uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# UploadThing (alternative image upload)
UPLOADTHING_TOKEN=""

# MercadoPago (can also be configured from admin panel)
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""

# PayPal Checkout: credenciales en Admin → Pagos (SiteSettings en DB). Opcional vía env si extendés el código.
# PAYPAL_CLIENT_ID=""
# PAYPAL_CLIENT_SECRET=""
# PayPal REST no admite UYU: conversión a USD con cotización BROU (portlet oficial). Si falla la lectura:
# PAYPAL_UYU_PER_USD=40
# Otra moneda de tienda no soportada por PayPal: monto_tienda * este valor = USD (solo si aplica).
# PAYPAL_FX_SITE_TO_USD=

# URL pública para webhooks de MercadoPago y enlaces en correos (mismo host que el sitio)
# Local: dejar vacío (usa NEXT_PUBLIC_SITE_URL / NEXTAUTH_URL / localhost)
BASE_URL=""
# Producción VPS:
# BASE_URL="https://karamba.com.uy"

# Logo para PDFs (certificado + factura). Si no existe, se usa texto "Karamba".
# KARAMBA_LOGO_PATH="C:\\ruta\\logo.png"

# Opcional: correos internos para avisos de pedidos nuevos (coma o punto y coma). Si no se define, se usan los destinatarios por defecto en código.
# STAFF_ORDER_NOTIFY_EMAILS="uno@ej.com,dos@ej.com"

# Email transaccional (Resend recomendado, o SMTP)
# Incluye el formulario en /contacto → karamba@vera.com.uy (copia a fkasmenko@gmail.com)
# https://resend.com — crear API key y dominio verificado
RESEND_API_KEY=""
# Remitente verificado, ej: "Karamba <hola@tudominio.com>"
EMAIL_FROM=""

# Alternativa SMTP (si no usás Resend)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""

# Analítica propia: minutos sin actividad para marcar carrito abandonado (al cargar /admin/analytics)
# ANALYTICS_CART_ABANDON_AFTER_MINUTES=45

# Instagram (sin API Meta): web_profile + GraphQL por shortcode (github.com/ahmedrangel/instagram-media-scraper)
# INSTAGRAM_USERNAME="karamba.uy"
# Opcional si Instagram cambia tokens: INSTAGRAM_IG_APP_ID= INSTAGRAM_GQL_DOC_ID= INSTAGRAM_GQL_LSD=
# Si falla el scrape: Admin → Configuración → feed manual JSON

# Log en consola qué imagen usa cada producto (solo dev; 1 = activo)
# NEXT_PUBLIC_DEBUG_PRODUCT_IMAGES=1
# DEBUG_PRODUCT_IMAGES=1

# YouTube: último video (RSS si falla playlist API o sin clave) + en vivo (API o embed sin clave)
# En VPS, si el scrape de youtube.com falla, el sitio usa un channel ID UC de respaldo + RSS.
# Recomendado: definir YOUTUBE_CHANNEL_ID con tu UC… para máxima fiabilidad.
# Get API key from Google Cloud Console → YouTube Data API v3
YOUTUBE_API_KEY=""
# Channel ID (UC…) desde YouTube Studio / URL del canal
YOUTUBE_CHANNEL_ID=""
# Si no hay CHANNEL_ID, se resuelve desde el @handle (por defecto SOMOS-KARAMBA)
YOUTUBE_CHANNEL_HANDLE="SOMOS-KARAMBA"
