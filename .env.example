# Database (Docker Compose: host es el servicio `db`, no uses localhost para la DB)
DATABASE_URL="postgresql://karamba:Majo1984_@db:5432/karamba?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-super-secret-key-change-this"
NEXTAUTH_URL="http://localhost:3000"

# URL pública del sitio (metadata SEO, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL="https://karamba.com.uy"

# Cloudinary (optional - for image uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# UploadThing (alternative image upload)
UPLOADTHING_TOKEN=""

# MercadoPago (can also be configured from admin panel)
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""

# URL pública para webhooks de MercadoPago
# En desarrollo: usar ngrok (ej: https://abc123.ngrok-free.app)
# En producción: usar el dominio real (ej: https://karamba.com.uy)
BASE_URL=""

# Logo para PDFs (certificado + factura). Si no existe, se usa texto "Karamba".
# KARAMBA_LOGO_PATH="C:\\ruta\\logo.png"

# Email transaccional (Resend recomendado, o SMTP)
# Incluye el formulario en /contacto → karamba@vera.com.uy (copia a fkasmenko@gmail.com)
# https://resend.com — crear API key y dominio verificado
RESEND_API_KEY=""
# Remitente verificado, ej: "Karamba <hola@tudominio.com>"
EMAIL_FROM=""

# Alternativa SMTP (si no usás Resend)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""

# Instagram (sin API Meta): web_profile + GraphQL por shortcode (github.com/ahmedrangel/instagram-media-scraper)
# INSTAGRAM_USERNAME="karamba.uy"
# Opcional si Instagram cambia tokens: INSTAGRAM_IG_APP_ID= INSTAGRAM_GQL_DOC_ID= INSTAGRAM_GQL_LSD=
# Si falla el scrape: Admin → Configuración → feed manual JSON

# Log en consola qué imagen usa cada producto (solo dev; 1 = activo)
# NEXT_PUBLIC_DEBUG_PRODUCT_IMAGES=1
# DEBUG_PRODUCT_IMAGES=1

# YouTube: último video (RSS si falla playlist API o sin clave) + en vivo (API o embed sin clave)
# Get API key from Google Cloud Console → YouTube Data API v3
YOUTUBE_API_KEY=""
# Channel ID (UC…) desde YouTube Studio / URL del canal
YOUTUBE_CHANNEL_ID=""
# Si no hay CHANNEL_ID, se resuelve desde el @handle (por defecto SOMOS-KARAMBA)
YOUTUBE_CHANNEL_HANDLE="SOMOS-KARAMBA"
